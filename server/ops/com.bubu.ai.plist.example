<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.bubu.ai</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/zsh</string>
    <string>-lc</string>
    <string>cd /Users/leoyuan/Desktop/leoworkspace/BubuTimeMachine/server/ai &amp;&amp; ./start_ai.sh</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>StandardOutPath</key>
  <string>/Users/leoyuan/Library/Logs/BubuTimeMachine/ai.out.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/leoyuan/Library/Logs/BubuTimeMachine/ai.err.log</string>
  <key>WorkingDirectory</key>
  <string>/Users/leoyuan/Desktop/leoworkspace/BubuTimeMachine/server/ai</string>
</dict>
</plist>
