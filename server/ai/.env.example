# 布布时光机 AI 服务 · 环境变量
# 复制为 .env 并填写。启动脚本会自动加载。

# DeepSeek（OpenAI 兼容协议）
# ⚠️ 填你自己的 key，绝不要把真实 key 提交到 git
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_FALLBACK_MODEL=deepseek-v4-pro
LLM_TIMEOUT=60

# 语音转写（可选，需 pip install faster-whisper）
WHISPER_MODEL=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE=int8

# 服务端口
AI_PORT=8000

# 服务监听地址（默认只绑本机回环，最安全）。
# 需经 Tailscale/内网访问时改成该机的 Tailscale 地址（如 100.x.x.x），勿裸公网放 0.0.0.0。
BUBU_AI_BIND=127.0.0.1

# 成长电影下载白名单：/movie/render 只允许下载指向【自托管 PocketBase 主机】的图片，
# 防 SSRF/LFI（否则持 key 者可让服务端读 file:///etc/passwd 或探内网/云元数据）。
# 填你 PocketBase 的完整 base url（含端口最精确）；留空 = 拒绝一切外部下载。
# 例：PB_BASE_URL=http://127.0.0.1:8090
PB_BASE_URL=
# 备选：只给 host 或 host:port（PB_BASE_URL 优先）。可逗号分隔多个。
# BUBU_PB_HOST=127.0.0.1:8090

# 服务鉴权（必填）：App 设置页「AI 访问密钥」填同一个值。
# 生成方式：openssl rand -hex 24
AI_API_KEY=

# 每个来源 IP 每分钟最多请求数（公网暴露时的最低防线）
AI_RATE_LIMIT_PER_MINUTE=30
