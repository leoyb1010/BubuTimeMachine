# 布布时光机 AI 服务 · 环境变量
# 复制为 .env 并填写。启动脚本会自动加载。

# DeepSeek（OpenAI 兼容协议）
DEEPSEEK_API_KEY=REVOKED-ROTATE-ME
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_FALLBACK_MODEL=deepseek-v4-pro
LLM_TIMEOUT=60

# 语音转写（可选，需 pip install faster-whisper）
WHISPER_MODEL=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE=int8

# 服务端口
AI_PORT=8000
